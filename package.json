{
  "name": "lead-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run test && bun run format:check && bun run build",
    "design:research": "node design-variants/run-lazyweb-research.mjs",
    "design:variants": "node design-variants/generate-redesign-worktrees.mjs",
    "design:screenshots": "node design-variants/capture-fullpage-screenshots.mjs",
    "design:stats": "node design-variants/stats.mjs",
    "design:restore": "node design-variants/restore-archive.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/lib/db/seed.ts --reset",
    "db:reset-demo": "tsx src/lib/db/seed.ts --reset"
  },
  "dependencies": {
    "@copilotkit/react-core": "^1.57.4",
    "@copilotkit/react-ui": "^1.57.4",
    "@copilotkit/runtime": "^1.57.4",
    "@tailwindcss/forms": "^0.5.10",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.468.0",
    "next": "^16.0.7",
    "postgres": "^3.4.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.7",
    "postcss": "^8.4.49",
    "prettier": "3.8.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "4.1.7"
  }
}
